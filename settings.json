{
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || printf \"\\a\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -Iseconds) SESSION_START model=${ANTHROPIC_MODEL:-claude}\" >> ~/.claude/timing.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff 2>/dev/null || printf \"\\a\""
          },
          {
            "type": "command",
            "command": "echo \"$(date -Iseconds) SESSION_STOP\" >> ~/.claude/timing.log"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "voiceEnabled": true,
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "terminal_bell"
}
